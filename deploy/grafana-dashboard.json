{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "id": null,
  "uid": "ch-analyzer-full",
  "title": "CH Analyzer - ClickHouse Monitoring",
  "description": "Comprehensive ClickHouse monitoring: health, memory, CPU, queries, parts, merges, mutations, disk, S3, inserts, alerts",
  "tags": ["clickhouse", "ch-analyzer", "monitoring"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "1m",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus" },
      { "name": "instance", "type": "query", "datasource": "${datasource}", "query": "label_values(ch_analyzer_health_score, instance)", "refresh": 2, "includeAll": true, "multi": true, "current": { "text": "All", "value": "$__all" } },
      { "name": "database", "type": "query", "datasource": "${datasource}", "query": "label_values(ch_analyzer_parts_count{instance=~\"$instance\"}, database)", "refresh": 2, "includeAll": true, "current": { "text": "All", "value": "$__all" } }
    ]
  },
  "annotations": {
    "list": [
      { "name": "Critical Alerts", "datasource": "${datasource}", "expr": "changes(ch_analyzer_active_alerts{instance=~\"$instance\",severity=\"critical\"}[1m]) > 0", "titleFormat": "Critical Alert on {{instance}}", "iconColor": "red", "enable": true }
    ]
  },
  "panels": [
    { "type": "row", "title": "Overview", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "collapsed": false },
    { "title": "Health Score", "type": "gauge", "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_health_score{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "#EAB308", "value": 50 }, { "color": "green", "value": 80 }] } } }, "options": { "reduceOptions": { "calcs": ["lastNotNull"] } } },
    { "title": "Critical Alerts", "type": "stat", "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 }, "datasource": "${datasource}", "targets": [{ "expr": "sum(ch_analyzer_active_alerts{instance=~\"$instance\",severity=\"critical\"}) by (instance)", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "noValue": "0", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }, "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" } },
    { "title": "Warning Alerts", "type": "stat", "gridPos": { "h": 6, "w": 4, "x": 8, "y": 1 }, "datasource": "${datasource}", "targets": [{ "expr": "sum(ch_analyzer_active_alerts{instance=~\"$instance\",severity=\"warn\"}) by (instance)", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "noValue": "0", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 1 }] } } }, "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" } },
    { "title": "Running Queries", "type": "stat", "gridPos": { "h": 6, "w": 4, "x": 12, "y": 1 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_queries_running{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 50 }, { "color": "red", "value": 100 }] } } }, "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" } },
    { "title": "Active Merges", "type": "stat", "gridPos": { "h": 6, "w": 4, "x": 16, "y": 1 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_merges_active{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 10 }, { "color": "red", "value": 20 }] } } }, "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" } },
    { "title": "Uptime", "type": "stat", "gridPos": { "h": 6, "w": 4, "x": 20, "y": 1 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_uptime_seconds{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "unit": "dtdurations" } }, "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "none", "graphMode": "none" } },

    { "type": "row", "title": "Memory", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 }, "collapsed": false },
    { "title": "Memory RSS", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_memory_rss_bytes{instance=~\"$instance\"}", "legendFormat": "RSS {{instance}}" }, { "expr": "ch_analyzer_memory_total_bytes{instance=~\"$instance\"}", "legendFormat": "Total {{instance}}" }], "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10, "lineWidth": 2 } } }, "options": { "tooltip": { "mode": "multi" } } },
    { "title": "Memory RSS %", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_memory_rss_bytes{instance=~\"$instance\"} / ch_analyzer_memory_total_bytes{instance=~\"$instance\"} * 100", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "fillOpacity": 15, "thresholdsStyle": { "mode": "line" } }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 85 }, { "color": "red", "value": 95 }] } } } },
    { "title": "CH Memory Tracking", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_memory_tracked_bytes{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10, "lineWidth": 2 } } } },

    { "type": "row", "title": "CPU & Load", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }, "collapsed": false },
    { "title": "CPU Busy %", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 0, "y": 17 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_cpu_user_percent{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "fillOpacity": 15, "thresholdsStyle": { "mode": "line" } }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 80 }, { "color": "red", "value": 95 }] } } } },
    { "title": "Load Average", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 8, "y": 17 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_load_average{instance=~\"$instance\",period=\"1\"}", "legendFormat": "1m {{instance}}" }, { "expr": "ch_analyzer_load_average{instance=~\"$instance\",period=\"5\"}", "legendFormat": "5m {{instance}}" }, { "expr": "ch_analyzer_load_average{instance=~\"$instance\",period=\"15\"}", "legendFormat": "15m {{instance}}" }], "fieldConfig": { "defaults": { "custom": { "fillOpacity": 5, "lineWidth": 2 } } }, "options": { "tooltip": { "mode": "multi" } } },
    { "title": "CPU Saturation", "type": "gauge", "gridPos": { "h": 8, "w": 8, "x": 16, "y": 17 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_cpu_user_percent{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 70 }, { "color": "red", "value": 90 }] } } }, "options": { "reduceOptions": { "calcs": ["lastNotNull"] } } },

    { "type": "row", "title": "Queries", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 }, "collapsed": false },
    { "title": "Running Queries", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 0, "y": 26 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_queries_running{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15, "lineWidth": 2 } } } },
    { "title": "Failed Queries (5m)", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 8, "y": 26 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_queries_failed_total{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15 }, "color": { "fixedColor": "red", "mode": "fixed" } } } },
    { "title": "Queries Running vs Failed", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 16, "y": 26 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_queries_running{instance=~\"$instance\"}", "legendFormat": "Running {{instance}}" }, { "expr": "ch_analyzer_queries_failed_total{instance=~\"$instance\"}", "legendFormat": "Failed {{instance}}" }], "fieldConfig": { "defaults": { "custom": { "fillOpacity": 20 } }, "overrides": [{ "matcher": { "id": "byRegexp", "options": "Failed.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }] } },

    { "type": "row", "title": "Parts & Merges", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 }, "collapsed": false },
    { "title": "Active Merges", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 0, "y": 35 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_merges_active{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15, "thresholdsStyle": { "mode": "line" } }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 10 }, { "color": "red", "value": 20 }] } } } },
    { "title": "Stuck Mutations", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 8, "y": 35 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_mutations_stuck{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } } },
    { "title": "Top Tables by Parts", "type": "timeseries", "gridPos": { "h": 8, "w": 8, "x": 16, "y": 35 }, "datasource": "${datasource}", "targets": [{ "expr": "topk(15, ch_analyzer_parts_count{instance=~\"$instance\",database=~\"$database\"})", "legendFormat": "{{instance}} {{database}}.{{table}}" }], "fieldConfig": { "defaults": { "custom": { "fillOpacity": 5 }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 1000 }, { "color": "red", "value": 3000 }] } } } },
    { "title": "Parts Count (Current)", "type": "table", "gridPos": { "h": 8, "w": 24, "x": 0, "y": 43 }, "datasource": "${datasource}", "targets": [{ "expr": "topk(20, ch_analyzer_parts_count{instance=~\"$instance\",database=~\"$database\"})", "format": "table", "instant": true }], "transformations": [{ "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true }, "renameByName": { "instance": "Instance", "database": "Database", "table": "Table", "Value": "Parts" } } }, { "id": "sortBy", "options": { "sort": [{ "field": "Parts", "desc": true }] } }], "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 1000 }, { "color": "red", "value": 3000 }] }, "custom": { "displayMode": "color-background-solid" } } } },

    { "type": "row", "title": "Disk & Storage", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 51 }, "collapsed": false },
    { "title": "Disk Usage %", "type": "gauge", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 52 }, "datasource": "${datasource}", "targets": [{ "expr": "(ch_analyzer_disk_used_bytes{instance=~\"$instance\"} / ch_analyzer_disk_total_bytes{instance=~\"$instance\"}) * 100", "legendFormat": "{{instance}} / {{disk}}" }], "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 80 }, { "color": "red", "value": 90 }] } } }, "options": { "reduceOptions": { "calcs": ["lastNotNull"] } } },
    { "title": "Disk Used Over Time", "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 52 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_disk_used_bytes{instance=~\"$instance\"}", "legendFormat": "{{instance}} {{disk}}" }], "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10 } } } },

    { "type": "row", "title": "S3 / Object Storage", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 60 }, "collapsed": false },
    { "title": "S3 Read Latency", "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 61 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_s3_read_latency_seconds{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 15, "thresholdsStyle": { "mode": "dashed" } }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 5 }, { "color": "red", "value": 15 }] } } } },
    { "title": "S3 Latency Gauge", "type": "gauge", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 61 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_s3_read_latency_seconds{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "min": 0, "max": 30, "unit": "s", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "#EAB308", "value": 5 }, { "color": "red", "value": 15 }] } } }, "options": { "reduceOptions": { "calcs": ["lastNotNull"] } } },

    { "type": "row", "title": "Insert Throughput", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 69 }, "collapsed": false },
    { "title": "Insert Rows (per instance)", "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 70 }, "datasource": "${datasource}", "targets": [{ "expr": "sum(ch_analyzer_insert_rows_total{instance=~\"$instance\"}) by (instance)", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15, "lineWidth": 2 } } } },
    { "title": "Insert Rows (top 10 tables)", "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 70 }, "datasource": "${datasource}", "targets": [{ "expr": "topk(10, ch_analyzer_insert_rows_total{instance=~\"$instance\",database=~\"$database\"})", "legendFormat": "{{instance}} {{database}}.{{table}}" }], "fieldConfig": { "defaults": { "custom": { "fillOpacity": 5 } } } },

    { "type": "row", "title": "Table Sizes", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 78 }, "collapsed": false },
    { "title": "Top 20 Tables by Size", "type": "table", "gridPos": { "h": 10, "w": 24, "x": 0, "y": 79 }, "datasource": "${datasource}", "targets": [{ "expr": "topk(20, ch_analyzer_table_size_bytes{instance=~\"$instance\",database=~\"$database\"})", "format": "table", "instant": true }], "transformations": [{ "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true }, "renameByName": { "instance": "Instance", "database": "Database", "table": "Table", "disk": "Disk", "Value": "Size" } } }, { "id": "sortBy", "options": { "sort": [{ "field": "Size", "desc": true }] } }], "fieldConfig": { "defaults": { "unit": "bytes" } } },
    { "title": "Table Size Over Time (top 10)", "type": "timeseries", "gridPos": { "h": 8, "w": 24, "x": 0, "y": 89 }, "datasource": "${datasource}", "targets": [{ "expr": "topk(10, ch_analyzer_table_size_bytes{instance=~\"$instance\",database=~\"$database\"})", "legendFormat": "{{instance}} {{database}}.{{table}} ({{disk}})" }], "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 5 } } } },

    { "type": "row", "title": "Health & Alerts", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 97 }, "collapsed": false },
    { "title": "Health Score Over Time", "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 0, "y": 98 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_health_score{instance=~\"$instance\"}", "legendFormat": "{{instance}}" }], "fieldConfig": { "defaults": { "min": 0, "max": 100, "custom": { "fillOpacity": 10, "lineWidth": 2, "thresholdsStyle": { "mode": "area" } }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "#EAB308", "value": 50 }, { "color": "green", "value": 80 }] } } } },
    { "title": "Alerts by Severity", "type": "timeseries", "gridPos": { "h": 8, "w": 12, "x": 12, "y": 98 }, "datasource": "${datasource}", "targets": [{ "expr": "ch_analyzer_active_alerts{instance=~\"$instance\",severity=\"critical\"}", "legendFormat": "Critical {{instance}}" }, { "expr": "ch_analyzer_active_alerts{instance=~\"$instance\",severity=\"warn\"}", "legendFormat": "Warn {{instance}}" }], "fieldConfig": { "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } }, "overrides": [{ "matcher": { "id": "byRegexp", "options": "Critical.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }, { "matcher": { "id": "byRegexp", "options": "Warn.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "#EAB308", "mode": "fixed" } }] }] } }
  ],
  "schemaVersion": 38
}
