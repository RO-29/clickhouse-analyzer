# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Anthropic API key — enables AI analysis in the ch-analyzer dashboard.
# Get yours at: https://console.anthropic.com/
# Alternatively, run `docker compose exec ch-analyzer claude auth login`
# once for OAuth-based auth (the claude-config volume persists the session).
ANTHROPIC_API_KEY=sk-ant-...

# Grafana admin password (default: admin)
GRAFANA_PASSWORD=admin
